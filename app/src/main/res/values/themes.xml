<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.VocalLock" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/midnight_slate</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.VocalLock.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/midnight_slate</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/trust_green_dim</item>
        <item name="postSplashScreenTheme">@style/Theme.VocalLock</item>
    </style>
</resources>