#!/usr/bin/env bash
commit_regex='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9_-]+\))?!?: .+'
error_msg="Aborting commit. Your commit message is invalid."
commit_msg=$(cat "$1")
if [[ ! $commit_msg =~ $commit_regex ]]; then
    echo ""
    echo "❌ $error_msg"
    echo "Please use Conventional Commits format:"
    echo "  type(scope): description"
    echo ""
    exit 1
fi
